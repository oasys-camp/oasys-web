# Environment Variables for Stripe Integration
# Copy this file to .env and fill in your values

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Site Configuration
SITE_URL=https://oasys.earth

# Email Configuration (optional - for future implementation)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@oasys.earth

# Analytics Configuration
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Netlify Configuration (automatically set by Netlify)
# NETLIFY_SITE_ID=your_netlify_site_id
# NETLIFY_BUILD_ID=your_build_id